generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Rol {
  id_rol     Int       @id @default(autoincrement())
  nombre_rol String    @db.VarChar(15)
  usuarios   Usuario[]
}

model Usuario {
  id_usuario       Int                   @id @default(autoincrement())
  correo           String                @unique @db.VarChar(75)
  nombres          String                @db.VarChar(25)
  apellidos        String                @db.VarChar(25)
  nombre_usuario   String                @unique @db.VarChar(25)
  contrasena       String                @db.VarChar(255)
  id_rol           Int
  fecha_registro   DateTime              @default(now())
  rol              Rol                   @relation(fields: [id_rol], references: [id_rol])
  cursos_visitados UltimaVisitaCurso[]
}

model Docente {
  id_docente  Int     @id @default(autoincrement())
  nombres     String  @db.VarChar(25)
  apellidos   String  @db.VarChar(25)
  correo      String  @unique @db.VarChar(75)
  descripcion String
  cursos      Curso[]
}

model Curso {
  id_curso             Int                   @id @default(autoincrement())
  nombre               String                @db.VarChar(25)
  codigo_curso         String                @unique @db.VarChar(10)
  url_imagen           String                @db.VarChar(255)
  descripcion          String
  id_docente           Int
  fecha_creacion_curso DateTime              @default(now())
  fecha_actualizacion  DateTime              @updatedAt
  docente              Docente               @relation(fields: [id_docente], references: [id_docente])
  clases               Clase[]
  usuarios_visitantes  UltimaVisitaCurso[]
}

model UltimaVisitaCurso {
  id_usuario_curso    Int      @id @default(autoincrement())
  id_usuario          Int
  id_curso            Int
  fecha_inicio        DateTime @default(now())
  fecha_ultima_visita DateTime @updatedAt
  usuario             Usuario  @relation(fields: [id_usuario], references: [id_usuario])
  curso               Curso    @relation(fields: [id_curso], references: [id_curso])

  @@unique([id_usuario, id_curso])
}

model Clase {
  id_clase             Int        @id @default(autoincrement())
  id_curso             Int
  titulo               String     @db.VarChar(50)
  descripcion          String
  url_youtube          String     @db.VarChar(150)
  fecha_creacion_clase DateTime   @default(now())
  curso                Curso      @relation(fields: [id_curso], references: [id_curso])
  materiales           Material[]
}

enum TipoMaterial {
  archivo
  enlace
  referencia
}

model Material {
  id_material        Int      @id @default(autoincrement())
  id_clase           Int
  tipo_material      TipoMaterial
  nombre_archivo     String   @db.VarChar(150)
  url_enlace         String?
  referencia_escrita String?
  fecha_subida       DateTime @default(now())
  clase              Clase    @relation(fields: [id_clase], references: [id_clase])
}
